{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.apvero.dev/plugin-manifest/1.0.0",
  "title": "Apvero Plugin Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "version", "apveroVersion", "entrypoint", "permissions", "digest"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)+$" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[a-z0-9.-]+)?$" },
    "apveroVersion": { "type": "string", "minLength": 1 },
    "entrypoint": { "type": "string", "minLength": 1 },
    "permissions": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "signature": { "type": "string" }
  }
}
