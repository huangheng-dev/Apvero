{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.apvero.dev/release-bundle-manifest/1.1.0",
  "title": "Apvero Release Bundle Manifest 1.1",
  "description": "Strict immutable release contract for CHAT and grounded RAG applications. This contract is approved in P2.0 and remains contract-only until the P2 runtime implements it.",
  "x-apvero-contract-status": "contract-only",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runtimeMode",
    "modelRouteVersion",
    "promptVersion",
    "outputSchemaVersion",
    "knowledgeBindings",
    "capabilityVersions",
    "policyVersions",
    "memoryPolicyVersion",
    "evaluationReportVersion",
    "runtimeParameters"
  ],
  "properties": {
    "schemaVersion": { "const": "1.1" },
    "runtimeMode": { "enum": ["CHAT", "RAG"] },
    "modelRouteVersion": { "$ref": "#/$defs/exactVersionReference" },
    "promptVersion": { "$ref": "#/$defs/exactVersionReference" },
    "outputSchemaVersion": { "$ref": "#/$defs/exactVersionReference" },
    "knowledgeBindings": {
      "type": "array",
      "maxItems": 16,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/knowledgeBinding" }
    },
    "capabilityVersions": {
      "type": "array",
      "maxItems": 64,
      "items": { "$ref": "#/$defs/exactVersionReference" },
      "uniqueItems": true
    },
    "policyVersions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": { "$ref": "#/$defs/exactVersionReference" },
      "uniqueItems": true
    },
    "memoryPolicyVersion": { "$ref": "#/$defs/exactVersionReference" },
    "evaluationReportVersion": { "$ref": "#/$defs/exactVersionReference" },
    "runtimeParameters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["temperature", "maxOutputTokens"],
      "properties": {
        "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
        "maxOutputTokens": { "type": "integer", "minimum": 1, "maximum": 200000 }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "runtimeMode": { "const": "CHAT" } },
        "required": ["runtimeMode"]
      },
      "then": {
        "properties": { "knowledgeBindings": { "maxItems": 0 } }
      }
    },
    {
      "if": {
        "properties": { "runtimeMode": { "const": "RAG" } },
        "required": ["runtimeMode"]
      },
      "then": {
        "properties": { "knowledgeBindings": { "minItems": 1 } }
      }
    }
  ],
  "$defs": {
    "exactVersionReference": {
      "type": "string",
      "minLength": 7,
      "maxLength": 240,
      "pattern": "^(?!.*(?:^|[@:/-])latest(?:$|[@:/-]))[a-z0-9][a-z0-9._:/-]*@[0-9]+\\.[0-9]+\\.[0-9]+(?:-[a-z0-9.-]+)?$"
    },
    "knowledgeBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["indexVersion", "retrievalPolicyVersion"],
      "properties": {
        "indexVersion": { "$ref": "#/$defs/exactVersionReference" },
        "retrievalPolicyVersion": { "$ref": "#/$defs/exactVersionReference" }
      }
    }
  }
}
