{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.apvero.dev/release-bundle-manifest/1.0.0",
  "title": "Apvero Release Bundle Manifest 1.0 (legacy compatibility)",
  "description": "Historical CHAT manifest contract. It remains readable during Apvero 0.x and includes the integer-version shorthand and runtime metadata emitted by the P1 implementation. New RAG releases must use manifest 1.1.",
  "x-apvero-contract-status": "legacy-live",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "modelRouteVersion",
    "promptVersion",
    "outputSchemaVersion",
    "knowledgeIndexVersions",
    "capabilityVersions",
    "policyVersions",
    "memoryPolicyVersion",
    "evaluationReportVersion",
    "runtimeParameters"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "modelRouteVersion": { "$ref": "#/$defs/versionReference" },
    "promptVersion": { "$ref": "#/$defs/versionReference" },
    "outputSchemaVersion": { "$ref": "#/$defs/versionReference" },
    "knowledgeIndexVersions": { "type": "array", "items": { "$ref": "#/$defs/versionReference" }, "uniqueItems": true },
    "capabilityVersions": { "type": "array", "items": { "$ref": "#/$defs/versionReference" }, "uniqueItems": true },
    "policyVersions": { "type": "array", "items": { "$ref": "#/$defs/versionReference" }, "uniqueItems": true },
    "memoryPolicyVersion": { "$ref": "#/$defs/versionReference" },
    "evaluationReportVersion": { "$ref": "#/$defs/versionReference" },
    "runtimeParameters": {
      "description": "Legacy 1.0 accepted either explicit runtime values or P1 generated configuration-source metadata.",
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["temperature", "maxOutputTokens"],
          "properties": {
            "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
            "maxOutputTokens": { "type": "integer", "minimum": 1, "maximum": 200000 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["configurationSource"],
          "properties": {
            "configurationSource": { "const": "application-draft" }
          }
        }
      ]
    }
  },
  "$defs": {
    "versionReference": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200,
      "description": "Legacy 1.0 permits the P1 integer shorthand (for example none@1) as well as semantic versions.",
      "pattern": "^(?!.*(?:^|[@:/-])latest(?:$|[@:/-])).+@(?:[0-9]+|[0-9]+\\.[0-9]+\\.[0-9]+(?:-[a-z0-9.-]+)?)$"
    }
  }
}
