{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.apvero.dev/release-bundle-manifest/1.0.0",
  "title": "Apvero Release Bundle Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "modelRouteVersion",
    "promptVersion",
    "outputSchemaVersion",
    "knowledgeIndexVersions",
    "capabilityVersions",
    "policyVersions",
    "memoryPolicyVersion",
    "evaluationReportVersion",
    "runtimeParameters"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "modelRouteVersion": { "$ref": "#/$defs/versionReference" },
    "promptVersion": { "$ref": "#/$defs/versionReference" },
    "outputSchemaVersion": { "$ref": "#/$defs/versionReference" },
    "knowledgeIndexVersions": { "type": "array", "items": { "$ref": "#/$defs/versionReference" }, "uniqueItems": true },
    "capabilityVersions": { "type": "array", "items": { "$ref": "#/$defs/versionReference" }, "uniqueItems": true },
    "policyVersions": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/versionReference" }, "uniqueItems": true },
    "memoryPolicyVersion": { "$ref": "#/$defs/versionReference" },
    "evaluationReportVersion": { "$ref": "#/$defs/versionReference" },
    "runtimeParameters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["temperature", "maxOutputTokens"],
      "properties": {
        "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
        "maxOutputTokens": { "type": "integer", "minimum": 1, "maximum": 100000 }
      }
    }
  },
  "$defs": {
    "versionReference": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200,
      "pattern": "^(?!.*(?:^|[@:/-])latest(?:$|[@:/-])).+@[0-9]+\\.[0-9]+\\.[0-9]+(?:-[a-z0-9.-]+)?$"
    }
  }
}
